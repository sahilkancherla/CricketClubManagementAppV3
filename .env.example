# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Express Server
PORT=3001
API_URL=http://localhost:3001
# Comma-separated list of allowed web origins (CORS). Leave unset locally to
# fall back to localhost; in production set to the web app origin(s), e.g.
# CORS_ORIGINS=https://app.yourdomain.com
CORS_ORIGINS=
# Max API requests per IP per 15-minute window (optional; defaults to 300).
RATE_LIMIT_MAX=300

# Frontend (Next.js)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:3001

# Expo
EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_URL=http://localhost:3001

# PayPal (stub)
PAYPAL_CLIENT_ID=paypal_client_id_placeholder
PAYPAL_CLIENT_SECRET=paypal_client_secret_placeholder
PAYPAL_WEBHOOK_ID=paypal_webhook_placeholder
